{
  "expo": {
    "name": "ChromaLab",
    "slug": "Colorimetria",
    "scheme": "colorimetria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["assets/fonts/*", "assets/images/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "O aplicativo utiliza o Bluetooth para se conectar ao colorímetro.",
        "NSBluetoothPeripheralUsageDescription": "O aplicativo precisa de acesso ao Bluetooth para comunicação com o sensor colorimétrico."
      },
      "associatedDomains": [
        "applinks:colorimetro-de-baixo-custo.firebaseapp.com"
      ]
    },
    "android": {
      "package": "com.colorimetrodebaixocusto.chromalab",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "colorimetro-de-baixo-custo.firebaseapp.com",
              "pathPrefix": "/__/auth/action"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "colorimetria"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5c787b73-100a-4ab4-9618-de0527306c35"
      }
    },
    "owner": "chromalab",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5c787b73-100a-4ab4-9618-de0527306c35"
    }
  }
}